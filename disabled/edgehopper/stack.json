{
  "id": "edgehopper",
  "name": "EdgeHopper",
  "region": "fullscreen",
  "display": "all",
  "clickThrough": true,
  "size": { "h": 0 },
  "permissions": ["cursor", "display", "sound"],
  "eventtap": [
    { "event": "mouseMoved",       "callback": "onMove" },
    { "event": "leftMouseDragged", "callback": "onMove" },
    { "event": "flagsChanged",     "callback": "onFlags" }
  ]
}
