{
  "id": "framemaster",
  "name": "FrameMaster",
  "region": "fullscreen",
  "size": { "h": 0 },
  "clickThrough": true,
  "level": "tooltip",
  "permissions": [
    "windows", "apps", "applescript", "display",
    "events", "app", "mouse"
  ],
  "eventtap": [
    { "event": "leftMouseDown", "callback": "click" },
    { "event": "flagsChanged",  "callback": "flags" }
  ]
}
