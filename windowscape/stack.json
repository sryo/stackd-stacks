{
  "id": "windowscape",
  "name": "WindowScape",
  "region": "fullscreen",
  "size": { "h": 0 },
  "clickThrough": true,
  "display": "primary",
  "permissions": ["windows", "spaces", "apps", "settings", "fs", "display", "mouse"],
  "handles": ["sd.window.created", "sd.window.destroyed", "sd.window.titleChanged", "sd.window.minimized", "sd.window.deminimized", "sd.window.moved"],
  "eventtap": [
    { "event": "scrollWheel",      "callback": "snapshotsScroll" },
    { "event": "rightMouseDown",   "callback": "snapshotsRightClick" },
    { "event": "leftMouseDown",    "callback": "snapshotsLeftClick" }
  ],
  "hotkeys": [
    { "key": "ctrl+cmd+,",            "callback": "toggleExcluded" },
    { "key": "ctrl+cmd+left",         "callback": "movePrev" },
    { "key": "ctrl+cmd+right",        "callback": "moveNext" },
    { "key": "ctrl+cmd+alt+left",     "callback": "moveScreenPrev" },
    { "key": "ctrl+cmd+alt+right",    "callback": "moveScreenNext" },
    { "key": "ctrl+cmd+0",            "callback": "resetWeights" },
    { "key": "ctrl+cmd+=",            "callback": "grow" },
    { "key": "ctrl+cmd+-",            "callback": "shrink" },
    { "key": "ctrl+cmd+w",            "callback": "cycleWidth" },
    { "key": "ctrl+cmd+f",            "callback": "toggleFullscreen" },
    { "key": "ctrl+cmd+r",            "callback": "forceRetile" },
    { "key": "ctrl+cmd+p",            "callback": "toggleExcluded" },
    { "key": "ctrl+cmd+d",            "callback": "toggleDebug" },
    { "key": "ctrl+cmd+m",            "callback": "minimize" },
    { "key": "ctrl+cmd+shift+r",      "callback": "snapshotsRestoreAll" },
    { "key": "ctrl+cmd+shift+x",      "callback": "snapshotsCloseAll" },
    { "key": "ctrl+cmd+shift+c",      "callback": "snapshotsClearAll" }
  ]
}
