{
  "id": "cloudpad",
  "name": "CloudPad",
  "anchor": { "edge": "top-right", "inset": [16, 16] },
  "size": { "w": 1, "h": 1 },
  "material": "none",
  "permissions": [
    "httpserver",
    "display",
    "events",
    "net",
    "mouse",
    "pasteboard",
    "cursor",
    "fs"
  ],
  "hotkeys": [
    { "key": "ctrl+cmd+c", "callback": "copyUrl" }
  ],
  "handles": ["bar.requestRegister", "cloudpad.copyUrl"]
}
