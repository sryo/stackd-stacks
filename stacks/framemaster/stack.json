{
  "id": "framemaster",
  "name": "FrameMaster",
  "region": "fullscreen",
  "size": { "h": 0 },
  "clickThrough": true,
  "level": "tooltip",
  "permissions": [
    "windows", "apps", "applescript", "display",
    "events", "app"
  ],
  "eventtap": [
    { "event": "leftMouseDown", "callback": "click", "consume": true, "requireRects": true },
    { "event": "flagsChanged",  "callback": "flags" },
    { "event": "mouseMoved",    "callback": "hover", "requireRects": true, "emitLeave": true }
  ]
}
