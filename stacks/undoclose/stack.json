{
  "id": "undoclose",
  "name": "Undo Close",
  "anchor": { "edge": "top-center", "inset": [80] },
  "size": { "w": 420, "h": 48 },
  "material": "glass",
  "cornerRadius": 12,
  "padding": 0,
  "level": "tooltip",
  "clickThrough": true,
  "permissions": [],
  "handles": ["sd.window.destroyed", "apptimeout.killed"],
  "hotkeys": [
    { "key": "cmd+alt+z", "callback": "undo" },
    { "key": "cmd+alt+p", "callback": "protect" }
  ]
}
